{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>Linkurious/renovate-config",
    "local>Linkurious/renovate-config:meta",
    "customManagers:dockerfileVersions",
    "customManagers:helmChartYamlAppVersions"
  ],
  "hostRules": [
    {
      "hostType": "docker",
      "matchHost": "https://public-pull.nexus3.linkurious.net",
      "token": "{{ secrets.mend_nexus_public_pull }}",
      "authType": "Basic"
    }
  ],
  "baseBranchPatterns": [
    "develop"
  ]
}
