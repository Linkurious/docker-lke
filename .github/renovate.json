{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>Linkurious/renovate-config",
    "local>Linkurious/renovate-config:meta",
    "customManagers:dockerfileVersions"
  ],
  "baseBranchPatterns": [
    "develop"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["**/Chart.yaml"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[a-zA-Z0-9-._]+?)\\s+depName=(?<depName>[^\\s]+?)(?: versioning=(?<versioning>[^\\s]+?))?\\s+appVersion:\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ]
}
